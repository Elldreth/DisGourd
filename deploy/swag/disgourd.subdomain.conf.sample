# DisGourd reverse-proxy config for SWAG.
#
# Copy to your SWAG config as:
#   <swag-appdata>/nginx/proxy-confs/disgourd.subdomain.conf
# then restart SWAG (SWAG_AUTORELOAD via inotify may not fire on Unraid's
# /mnt/user FUSE share, so a restart is the reliable way to load it).
# Serves https://disgourd.<yourdomain> -> the disgourd container.
#
# Requires:
#   • "disgourd" covered by your SWAG certificate (SUBDOMAINS env, or a wildcard).
#   • The disgourd container on the same Docker network as SWAG (so the name
#     "disgourd" resolves). See docker-compose.yml.
#
# WebSockets (the /gateway realtime connection) work automatically: SWAG's
# bundled proxy.conf already sets proxy_http_version and the Upgrade/Connection
# headers. Do NOT re-add them here — a duplicate proxy_http_version makes
# `nginx -t` fail and SWAG falls back to its default page.

server {
    listen 443 ssl;
    listen [::]:443 ssl;

    server_name disgourd.*;

    include /config/nginx/ssl.conf;

    # DisGourd streams file uploads (images/videos) — don't let nginx cap them.
    client_max_body_size 0;

    location / {
        include /config/nginx/proxy.conf;
        include /config/nginx/resolver.conf;
        set $upstream_app disgourd;
        set $upstream_port 3000;
        set $upstream_proto http;
        proxy_pass $upstream_proto://$upstream_app:$upstream_port;
    }
}
